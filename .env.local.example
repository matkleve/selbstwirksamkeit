# Supabase — get these from your project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://DEIN_PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=DEIN_ANON_KEY

# Mirror dev: always re-run detectors on open (still persists to mirror_candidates)
# NEXT_PUBLIC_MIRROR_DEV_MODE=true

# Test script (scripts/test-mirror.ts) — service role bypasses RLS
# SUPABASE_SERVICE_ROLE_KEY=...

# Phase 2 embeddings — Mistral AI (server-side only, never NEXT_PUBLIC_)
# MISTRAL_API_KEY=...

# Local Docker: npm run docker:up writes .env.docker (host.docker.internal:54321)
# See docker/README.md
