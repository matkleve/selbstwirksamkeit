FROM node:22-alpine

WORKDIR /app

RUN apk add --no-cache libc6-compat

COPY package.json package-lock.json ./
RUN npm ci \
  && mkdir -p .next \
  && chown -R node:node /app/node_modules /app/.next

USER node

EXPOSE 3000

# Source is bind-mounted at runtime; deps + cache use anonymous volumes (see compose).
CMD ["npm", "run", "dev", "--", "-H", "0.0.0.0", "-p", "3000"]
