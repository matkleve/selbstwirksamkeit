# Generated by: npm run docker:env
# Copy manually if needed: cp .env.docker.example .env.docker
#
# Supabase runs on the host via `supabase start` (ports 54321 API, 54323 Studio).
# From inside the web container, reach the host API at host.docker.internal.

NEXT_PUBLIC_SUPABASE_URL=http://host.docker.internal:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
